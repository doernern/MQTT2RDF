@base <http://example.com/mapping/> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rr:       <http://www.w3.org/ns/r2rml#> .
@prefix rml:      <http://semweb.mmlab.be/ns/rml#> .
@prefix ql:       <http://semweb.mmlab.be/ns/ql#> .
@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt:     <http://qudt.org/schema/qudt/> .
@prefix unit:     <http://qudt.org/vocab/unit/> .
@prefix mqtt4ssn: <https://doernern.github.io/MQTT4SSNOntology/MQTT4SSN.owl#> .

###################################
# Logical source: Node-RED JSON file
###################################
<#Base>
  rml:source "/work/data/in/unsuback.json" ;
  rml:referenceFormulation ql:JSONPath ;
  rml:iterator "$" .

############################
# MQTT UnsubackPacket
############################

<#UnsubackPacketMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/UnsubackPacket_{timestamp}" ;
    rr:class mqtt4ssn:UnsubackPacket
  ] ;

  # Link to UnsubackFixedHeader
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasUnsubackFixedHeader ;
    rr:objectMap [ rr:parentTriplesMap <#UnsubackFixedHeaderMapping> ] ;
  ] ;
  # Link to UnsubackVariableHeader
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasUnsubackVariableHeader ;
    rr:objectMap [ rr:parentTriplesMap <#UnsubackVariableHeaderMapping> ] ;
  ] .
  # Link to UnsubackPayload  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasUnsubackPayload ;
    rr:objectMap [ rr:parentTriplesMap <#UnsubackPayloadMapping> ] ;
  ] .

############################
# MQTT UnsubackFixedHeader
############################

<#UnsubackFixedHeaderMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/UnsubackFixedHeader_{timestamp}" ;
    rr:class mqtt4ssn:UnsubackFixedHeader
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasControlPacketType ;
    rr:objectMap [ rml:reference "unsubackPacket.fixedHeader.controlPacketType" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasRemainingLength ;
    rr:objectMap [ rml:reference "unsubackPacket.fixedHeader.remainingLength" ; rr:datatype xsd:byte ]
  ] .

############################
# MQTT UnsubackVariableHeader
############################

<#UnsubackVariableHeaderMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/UnsubackVariableHeader_{timestamp}" ;
    rr:class mqtt4ssn:UnsubackVariableHeader
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPacketIdentifier ;
    rr:objectMap [ rml:reference "unsubackPacket.variableHeader.packetIdentifier" ; rr:datatype xsd:integer ]
  ] ;

  # Link to UnsubackProperties
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasUnsubackProperties ;
    rr:objectMap [ rr:parentTriplesMap <#UnsubackPropertiesMapping> ] ;
  ] .

<#UnsubackPropertiesMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/UnsubackProperties_{timestamp}" ;
    rr:class mqtt4ssn:UnsubackProperties
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPropertyLength ;
    rr:objectMap [ rml:reference "unsubackPacket.variableHeader.unsubackProperties.propertyLength" ; rr:datatype xsd:integer ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasReasonString ;
    rr:objectMap [ rml:reference "unsubackPacket.variableHeader.unsubackProperties.reasonString" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasUserProperty ;
    rr:objectMap [ rml:reference "unsubackPacket.variableHeader.unsubackProperties.userProperty" ; rr:datatype xsd:string ]
  ] .

############################
# MQTT UnsubackPayload
############################

<#UnsubackPayloadMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/UnsubackPayload_{timestamp}" ;
    rr:class mqtt4ssn:UnsubackPayload
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasUnsubackReasonCode ;
    rr:objectMap [ rml:reference "unsubackPacket.variableHeader.unsubackReasonCode" ; rr:datatype xsd:integer ]
  ] .

############################
# MQTT NetworkConnection
############################

<#NetworkConnectionMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/NetworkConnection_{network.connection}" ;
    rr:class mqtt4ssn:NetworkConnection
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:usesTLS ;
    rr:objectMap [ rml:reference "network.tls" ; rr:datatype xsd:boolean ]
  ] ;

  # Link to Client
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:isInitiatedBy ;
    rr:objectMap [ rr:parentTriplesMap <#ClientMapping> ] ;
  ] ;
  # Link to NetworkParticipants
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasParticipant ;
    rr:objectMap [ rr:parentTriplesMap <#BrokerMapping> ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasParticipant ;
    rr:objectMap [ rr:parentTriplesMap <#ClientMapping> ] ;
  ] .

############################
# MQTT Broker
############################

<#BrokerMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/Broker_{network.broker.brokerID}" ;
    rr:class mqtt4ssn:Broker
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasHostAddress ;
    rr:objectMap [ rml:reference "network.broker.hostAddress" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPortNumber ;
    rr:objectMap [ rml:reference "network.broker.portNumber" ; rr:datatype xsd:integer ]
  ] ;

  # Link to NetworkConnectionMapping
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:isAcceptedBy ;
    rr:objectMap [ rr:parentTriplesMap <#NetworkConnectionMapping> ] ;
  ] ;
  # Link to Client
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasConnectedClient ;
    rr:objectMap [ rr:parentTriplesMap <#ClientMapping> ] ;
  ] ;
  # Link to UnsubackPacket
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:sendsUnsubackPacket ;
    rr:objectMap [ rr:parentTriplesMap <#UnsubackPacketMapping> ] ;
  ] .

############################
# MQTT Client
############################

<#ClientMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/Client_{network.client.clientID}" ;
    rr:class mqtt4ssn:Client
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasClientID ;
    rr:objectMap [ rml:reference "network.client.clientID" ; rr:datatype xsd:integer ]
  ] ;

  # Link to Broker
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:isConnectedToBroker ;
    rr:objectMap [ rr:parentTriplesMap <#BrokerMapping> ] ;
  ] ;
  # Link to UnsubackPacket
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:receivesUnsubackPacket ;
    rr:objectMap [ rr:parentTriplesMap <#UnsubackPacketMapping> ] ;
  ] .