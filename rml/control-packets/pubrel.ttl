@base <http://example.com/mapping/> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rr:       <http://www.w3.org/ns/r2rml#> .
@prefix rml:      <http://semweb.mmlab.be/ns/rml#> .
@prefix ql:       <http://semweb.mmlab.be/ns/ql#> .
@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt:     <http://qudt.org/schema/qudt/> .
@prefix unit:     <http://qudt.org/vocab/unit/> .
@prefix mqtt4ssn: <https://doernern.github.io/MQTT4SSNOntology/MQTT4SSN.owl#> .

###################################
# Logical source: Node-RED JSON file
###################################
<#Base>
  rml:source "/work/data/in/pubrel.json" ;
  rml:referenceFormulation ql:JSONPath ;
  rml:iterator "$" .

############################
# MQTT PubrelPacket
############################

<#PubrelPacketMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/PubrelPacket_{timestamp}" ;
    rr:class mqtt4ssn:PubrelPacket
  ] ;

  # Link to PubrelFixedHeader
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPubrelFixedHeader ;
    rr:objectMap [ rr:parentTriplesMap <#PubrelFixedHeaderMapping> ] ;
  ] ;
  # Link to PubrelVariableHeader
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPubrelVariableHeader ;
    rr:objectMap [ rr:parentTriplesMap <#PubrelVariableHeaderMapping> ] ;
  ] .

############################
# MQTT PubrelFixedHeader
############################

<#PubrelFixedHeaderMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/PubrelFixedHeader_{timestamp}" ;
    rr:class mqtt4ssn:PubrelFixedHeader
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasControlPacketType ;
    rr:objectMap [ rml:reference "pubrelPacket.fixedHeader.controlPacketType" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasRemainingLength ;
    rr:objectMap [ rml:reference "pubrelPacket.fixedHeader.remainingLength" ; rr:datatype xsd:byte ]
  ] .

############################
# MQTT PubrelVariableHeader
############################

<#PubrelVariableHeaderMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/PubrelVariableHeader_{timestamp}" ;
    rr:class mqtt4ssn:PubrelVariableHeader
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPacketIdentifier ;
    rr:objectMap [ rml:reference "pubrelPacket.variableHeader.packetIdentifier" ; rr:datatype xsd:integer ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPubrelReasonCode ;
    rr:objectMap [ rml:reference "pubrelPacket.variableHeader.pubrelReasonCode" ; rr:datatype xsd:integer ]
  ] ;

  # Link to PubrelProperties
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPubrelProperties ;
    rr:objectMap [ rr:parentTriplesMap <#PubrelPropertiesMapping> ] ;
  ] .

<#PubrelPropertiesMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/PubrelProperties_{timestamp}" ;
    rr:class mqtt4ssn:PubrelProperties
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPropertyLength ;
    rr:objectMap [ rml:reference "pubrelPacket.variableHeader.pubrelProperties.propertyLength" ; rr:datatype xsd:integer ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasReasonString ;
    rr:objectMap [ rml:reference "pubrelPacket.variableHeader.pubrelProperties.reasonString" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasUserProperty ;
    rr:objectMap [ rml:reference "pubrelPacket.variableHeader.pubrelProperties.userProperty" ; rr:datatype xsd:string ]
  ] .

############################
# MQTT NetworkConnection
############################

<#NetworkConnectionMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/NetworkConnection_{network.connection}" ;
    rr:class mqtt4ssn:NetworkConnection
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:usesTLS ;
    rr:objectMap [ rml:reference "network.tls" ; rr:datatype xsd:boolean ]
  ] ;

  # Link to Client
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:isInitiatedBy ;
    rr:objectMap [ rr:parentTriplesMap <#ClientMapping> ] ;
  ] ;
  # Link to NetworkParticipants
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasParticipant ;
    rr:objectMap [ rr:parentTriplesMap <#BrokerMapping> ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasParticipant ;
    rr:objectMap [ rr:parentTriplesMap <#ClientMapping> ] ;
  ] .

############################
# MQTT Broker
############################

<#BrokerMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/Broker_{network.broker.brokerID}" ;
    rr:class mqtt4ssn:Broker
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasHostAddress ;
    rr:objectMap [ rml:reference "network.broker.hostAddress" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPortNumber ;
    rr:objectMap [ rml:reference "network.broker.portNumber" ; rr:datatype xsd:integer ]
  ] ;

  # Link to NetworkConnectionMapping
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:isAcceptedBy ;
    rr:objectMap [ rr:parentTriplesMap <#NetworkConnectionMapping> ] ;
  ] ;
  # Link to Client
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasConnectedClient ;
    rr:objectMap [ rr:parentTriplesMap <#ClientMapping> ] ;
  ] ;
  # Link to PubrelPacket
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:receivesPubrelPacket ;
    rr:objectMap [ rr:parentTriplesMap <#PubrelPacketMapping> ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:sendsPubrelPacket ;
    rr:objectMap [ rr:parentTriplesMap <#PubrelPacketMapping> ] ;
  ] .

############################
# MQTT Client
############################

<#ClientMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/Client_{network.client.clientID}" ;
    rr:class mqtt4ssn:Client
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasClientID ;
    rr:objectMap [ rml:reference "network.client.clientID" ; rr:datatype xsd:integer ]
  ] ;

  # Link to Broker
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:isConnectedToBroker ;
    rr:objectMap [ rr:parentTriplesMap <#BrokerMapping> ] ;
  ] ;
  # Link to PubrelPacket
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:receivesPubrelPacket ;
    rr:objectMap [ rr:parentTriplesMap <#PubrelPacketMapping> ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:sendsPubrelPacket ;
    rr:objectMap [ rr:parentTriplesMap <#PubrelPacketMapping> ] ;
  ] .