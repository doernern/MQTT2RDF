@base <http://example.com/mapping/> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rr:       <http://www.w3.org/ns/r2rml#> .
@prefix rml:      <http://semweb.mmlab.be/ns/rml#> .
@prefix ql:       <http://semweb.mmlab.be/ns/ql#> .
@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt:     <http://qudt.org/schema/qudt/> .
@prefix unit:     <http://qudt.org/vocab/unit/> .
@prefix mqtt4ssn: <https://doernern.github.io/MQTT4SSNOntology/MQTT4SSN.owl#> .

###################################
# Logical source: Node-RED JSON file
###################################
<#Base>
  rml:source "/work/data/in/auth.json" ;
  rml:referenceFormulation ql:JSONPath ;
  rml:iterator "$[*]" .

############################
# MQTT AuthPacket
############################

<#AuthPacketMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/AuthPacket_{timestamp}" ;
    rr:class mqtt4ssn:AuthPacket
  ] ;

  # Link to AuthFixedHeader
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasAuthFixedHeader ;
    rr:objectMap [ rr:parentTriplesMap <#AuthFixedHeaderMapping> ] ;
  ] ;
  # Link to AuthVariableHeader
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasAuthVariableHeader ;
    rr:objectMap [ rr:parentTriplesMap <#AuthVariableHeaderMapping> ] ;
  ] .

############################
# MQTT AuthFixedHeader
############################

<#AuthFixedHeaderMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/AuthFixedHeader_{timestamp}" ;
    rr:class mqtt4ssn:AuthFixedHeader
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasControlPacketType ;
    rr:objectMap [ rml:reference "authPacket.fixedHeader.controlPacketType" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasRemainingLength ;
    rr:objectMap [ rml:reference "authPacket.fixedHeader.remainingLength" ; rr:datatype xsd:byte ]
  ] .

############################
# MQTT AuthVariableHeader
############################

<#AuthVariableHeaderMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/AuthVariableHeader_{timestamp}" ;
    rr:class mqtt4ssn:AuthVariableHeader
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasAuthReasonCode ;
    rr:objectMap [ rml:reference "authPacket.variableHeader.authReasonCode" ; rr:datatype xsd:string ]
  ] ;

  # Link to AuthProperties
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasAuthProperties ;
    rr:objectMap [ rr:parentTriplesMap <#AuthPropertiesMapping> ] ;
  ] .

<#AuthPropertiesMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/AuthProperties_{timestamp}" ;
    rr:class mqtt4ssn:AuthProperties
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPropertyLength ;
    rr:objectMap [ rml:reference "authPacket.variableHeader.authProperties.propertyLength" ; rr:datatype xsd:nonNegativeInteger ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasAuthentificationMethod ;
    rr:objectMap [ rml:reference "authPacket.variableHeader.authProperties.authentificationMethod" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasAuthentificationData ;
    rr:objectMap [ rml:reference "authPacket.variableHeader.authProperties.authentificationData" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasReasonString ;
    rr:objectMap [ rml:reference "authPacket.variableHeader.authProperties.reasonString" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasUserProperty ;
    rr:objectMap [ rml:reference "authPacket.variableHeader.authProperties.userProperty" ; rr:datatype xsd:string ]
  ] .

############################
# MQTT NetworkConnection
############################

<#NetworkConnectionMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/NetworkConnection_{network.connection}" ;
    rr:class mqtt4ssn:NetworkConnection
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:usesTLS ;
    rr:objectMap [ rml:reference "network.tls" ; rr:datatype xsd:boolean ]
  ] ;

  # Link to Client
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:isInitiatedBy ;
    rr:objectMap [ rr:parentTriplesMap <#ClientMapping> ] ;
  ] ;
  # Link to NetworkParticipants
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasParticipant ;
    rr:objectMap [ rr:parentTriplesMap <#BrokerMapping> ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasParticipant ;
    rr:objectMap [ rr:parentTriplesMap <#ClientMapping> ] ;
  ] .

############################
# MQTT Broker
############################

<#BrokerMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/Broker_{network.broker.brokerID}" ;
    rr:class mqtt4ssn:Broker
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasHostAddress ;
    rr:objectMap [ rml:reference "network.broker.hostAddress" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPortNumber ;
    rr:objectMap [ rml:reference "network.broker.portNumber" ; rr:datatype xsd:unsignedShort ]
  ] ;

  # Link to NetworkConnectionMapping
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:isAcceptedBy ;
    rr:objectMap [ rr:parentTriplesMap <#NetworkConnectionMapping> ] ;
  ] ;
  # Link to Client
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasConnectedClient ;
    rr:objectMap [ rr:parentTriplesMap <#ClientMapping> ] ;
  ] ;
  # Link to AuthPacket
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:receivesAuthPacket ;
    rr:objectMap [ rr:parentTriplesMap <#AuthPacketMapping> ] ;
  ] ;
  # Link to AuthPacket
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:sendsAuthPacket ;
    rr:objectMap [ rr:parentTriplesMap <#AuthPacketMapping> ] ;
  ] .

############################
# MQTT Client
############################

<#ClientMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/Client_{network.client.clientID}" ;
    rr:class mqtt4ssn:Client
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasClientID ;
    rr:objectMap [ rml:reference "network.client.clientID" ; rr:datatype xsd:string ]
  ] ;

  # Link to Broker
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:isConnectedToBroker ;
    rr:objectMap [ rr:parentTriplesMap <#BrokerMapping> ] ;
  ] ;
  # Link to AuthPacket
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:receivesAuthPacket ;
    rr:objectMap [ rr:parentTriplesMap <#AuthPacketMapping> ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:sendsAuthPacket ;
    rr:objectMap [ rr:parentTriplesMap <#AuthPacketMapping> ] ;
  ] .