@base <http://example.com/mapping/> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rr:       <http://www.w3.org/ns/r2rml#> .
@prefix rml:      <http://semweb.mmlab.be/ns/rml#> .
@prefix ql:       <http://semweb.mmlab.be/ns/ql#> .
@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt:     <http://qudt.org/schema/qudt/> .
@prefix unit:     <http://qudt.org/vocab/unit/> .
@prefix mqtt4ssn: <https://doernern.github.io/MQTT4SSNOntology/MQTT4SSN.owl#> .

###################################
# Logical source: Node-RED JSON file
###################################
<#Base>
  rml:source "/work/data/in/connect.json" ;
  rml:referenceFormulation ql:JSONPath ;
  rml:iterator "$[*]" .

############################
# MQTT ConnectPacket
############################

<#ConnectPacketMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/ConnectPacket_{timestamp}" ;
    rr:class mqtt4ssn:ConnectPacket
  ] ;

  # Link to ConnectFixedHeader
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasConnectFixedHeader ;
    rr:objectMap [ rr:parentTriplesMap <#ConnectFixedHeaderMapping> ] ;
  ] ;
  # Link to ConnectVariableHeader
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasConnectVariableHeader ;
    rr:objectMap [ rr:parentTriplesMap <#ConnectVariableHeaderMapping> ] ;
  ] ;
  # Link to ConnectPayload
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasConnectPayload ;
    rr:objectMap [ rr:parentTriplesMap <#ConnectPayloadMapping> ] ;
  ] .

############################
# MQTT ConnectFixedHeader
############################

<#ConnectFixedHeaderMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/ConnectFixedHeader_{timestamp}" ;
    rr:class mqtt4ssn:ConnectFixedHeader
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasControlPacketType ;
    rr:objectMap [ rml:reference "connectPacket.fixedHeader.controlPacketType" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasRemainingLength ;
    rr:objectMap [ rml:reference "connectPacket.fixedHeader.remainingLength" ; rr:datatype xsd:byte ]
  ] .

############################
# MQTT ConnectVariableHeader
############################

<#ConnectVariableHeaderMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/ConnectVariableHeader_{timestamp}" ;
    rr:class mqtt4ssn:ConnectVariableHeader
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasProtocolName ;
    rr:objectMap [ rml:reference "connectPacket.variableHeader.protocolName" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasProtocolVersion ;
    rr:objectMap [ rml:reference "connectPacket.variableHeader.protocolVersion" ; rr:datatype xsd:unsignedByte ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasUserNameFlag ;
    rr:objectMap [ rml:reference "connectPacket.variableHeader.connectFlags.userNameFlag" ; rr:datatype xsd:boolean ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPasswortFlag ;
    rr:objectMap [ rml:reference "connectPacket.variableHeader.connectFlags.passwordFlag" ; rr:datatype xsd:integer ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasWillRetain ;
    rr:objectMap [ rml:reference "connectPacket.variableHeader.connectFlags.willRetain" ; rr:datatype xsd:boolean ]
  ] ;
    rr:predicateObjectMap [
    rr:predicate mqtt4ssn:haswillQoS ;
    rr:objectMap [ rml:reference "connectPacket.variableHeader.connectFlags.willQoS" ; rr:datatype xsd:integer ]
  ] ;
    rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasWillFlag ;
    rr:objectMap [ rml:reference "connectPacket.variableHeader.connectFlags.willFlag" ; rr:datatype xsd:boolean ]
  ] ;
    rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasCleanStart ;
    rr:objectMap [ rml:reference "connectPacket.variableHeader.connectFlags.cleanStart" ; rr:datatype xsd:boolean ]
  ] ;
    rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasKeepAlive ;
    rr:objectMap [ rml:reference "connectPacket.variableHeader.connectFlags.cleanStart" ; rr:datatype xsd:unsignedShort ]
  ] ;

  # Link to ConnectProperties
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasConnectProperties ;
    rr:objectMap [ rr:parentTriplesMap <#ConnectPropertiesMapping> ] ;
  ] .

<#ConnectPropertiesMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/ConnectProperties_{timestamp}" ;
    rr:class mqtt4ssn:ConnectProperties
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPropertyLength ;
    rr:objectMap [ rml:reference "connectPacket.variableHeader.connectProperties.propertyLength" ; rr:datatype xsd:nonNegativeInteger ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasSessionExpiryInterval ;
    rr:objectMap [ rml:reference "connectPacket.variableHeader.connectProperties.sessionExpiryInterval" ; rr:datatype xsd:unsignedInt ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasReceiveMaximum ;
    rr:objectMap [ rml:reference "connectPacket.variableHeader.connectProperties.receiveMaximum" ; rr:datatype xsd:unsignedShort ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasMaximumPacketSize ;
    rr:objectMap [ rml:reference "connectPacket.variableHeader.connectProperties.maximumPacketSize" ; rr:datatype xsd:unsignedInt ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasTopicAliasMaximum ;
    rr:objectMap [ rml:reference "connectPacket.variableHeader.connectProperties.topicAliasMaximum" ; rr:datatype xsd:unsignedShort ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasRequestResponseInformation ;
    rr:objectMap [ rml:reference "connectPacket.variableHeader.connectProperties.requestResponseInformation" ; rr:datatype xsd:boolean ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasRequestProblemInformation ;
    rr:objectMap [ rml:reference "connectPacket.variableHeader.connectProperties.requestProblemInformation" ; rr:datatype xsd:boolean ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasUserProperty ;
    rr:objectMap [ rml:reference "connectPacket.variableHeader.connectProperties.userProperty" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasAuthenticationMethod ;
    rr:objectMap [ rml:reference "connectPacket.variableHeader.connectProperties.authenticationMethod" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasAuthenticationData ;
    rr:objectMap [ rml:reference "connectPacket.variableHeader.connectProperties.authenticationData" ; rr:datatype xsd:string ]
  ] .

############################
# MQTT ConnectPayload
############################

<#ConnectPayloadMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/ConnectPayload_{timestamp}" ;
    rr:class mqtt4ssn:ConnectPayload
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasClientID ;
    rr:objectMap [ rml:reference "connectPacket.payload.clientID" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasWillPayload ;
    rr:objectMap [ rml:reference "connectPacket.payload.willPayload" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasUserName ;
    rr:objectMap [ rml:reference "connectPacket.payload.userName" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPassword ;
    rr:objectMap [ rml:reference "connectPacket.payload.password" ; rr:datatype xsd:string ]
  ] ;

  # Link to WillProperties
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasWillProperties ;
    rr:objectMap [ rr:parentTriplesMap <#WillPropertiesMapping> ] ;
  ] ;

  #Link to WillTopic
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasWillTopic ;
    rr:objectMap [ rr:parentTriplesMap <#WillTopicMapping> ] ;
  ] .

<#WillPropertiesMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/WillProperties_{timestamp}" ;
    rr:class mqtt4ssn:WillProperties
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPropertyLength ;
    rr:objectMap [ rml:reference "connectPacket.payload.willProperties.propertyLength" ; rr:datatype xsd:nonNegativeInteger ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasWillDelayInterval ;
    rr:objectMap [ rml:reference "connectPacket.payload.willProperties.willDelayInterval" ; rr:datatype xsd:unsignedInt ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPayloadFormatIndicator ;
    rr:objectMap [ rml:reference "connectPacket.payload.willProperties.payloadFormatIndicator" ; rr:datatype xsd:boolean ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasMessageExpiryInterval ;
    rr:objectMap [ rml:reference "connectPacket.payload.willProperties.messageExpiryInterval" ; rr:datatype xsd:unsignedInt ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasContentType ;
    rr:objectMap [ rml:reference "connectPacket.payload.willProperties.contentType" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasCorrelationData ;
    rr:objectMap [ rml:reference "connectPacket.payload.willProperties.correlationData" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasUserProperty ;
    rr:objectMap [ rml:reference "connectPacket.payload.willProperties.userProperty" ; rr:datatype xsd:integer ]
  ] ;

  #Link to ResponseTopic
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasResponseTopic ;
    rr:objectMap [ rr:parentTriplesMap <#ResponseTopicMapping> ] ;
  ] .

############################
# WillTopic
############################

<#WillTopicMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/Topic_{connectPacket.payload.willTopic}" ;
    rr:class mqtt4ssn:Topic ;
  ] ;

  rr:predicateObjectMap [
    rr:predicate rdfs:label;
    rr:objectMap [ rml:reference "connectPacket.payload.willTopic" ; rr:datatype xsd:string ] ;
  ] .

############################
# ResponseTopic
############################

<#ResponseTopicMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/Topic_{connectPacket.payload.willProperties.responseTopic}" ;
    rr:class mqtt4ssn:Topic ;
  ] ;

  rr:predicateObjectMap [
    rr:predicate rdfs:label;
    rr:objectMap [ rml:reference "connectPacket.payload.willProperties.responseTopic" ; rr:datatype xsd:string ] ;
  ] .

############################
# MQTT NetworkConnection
############################

<#NetworkConnectionMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/NetworkConnection_{network.connection}" ;
    rr:class mqtt4ssn:NetworkConnection
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:usesTLS ;
    rr:objectMap [ rml:reference "network.tls" ; rr:datatype xsd:boolean ]
  ] ;

  # Link to Client
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:isInitiatedBy ;
    rr:objectMap [ rr:parentTriplesMap <#ClientMapping> ] ;
  ] ;
  # Link to NetworkParticipants
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasParticipant ;
    rr:objectMap [ rr:parentTriplesMap <#BrokerMapping> ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasParticipant ;
    rr:objectMap [ rr:parentTriplesMap <#ClientMapping> ] ;
  ] .

############################
# MQTT Broker
############################

<#BrokerMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/Broker_{network.broker.brokerID}" ;
    rr:class mqtt4ssn:Broker
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasHostAddress ;
    rr:objectMap [ rml:reference "network.broker.hostAddress" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPortNumber ;
    rr:objectMap [ rml:reference "network.broker.portNumber" ; rr:datatype xsd:unsignedShort ]
  ] ;

  # Link to NetworkConnection
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:isAcceptedBy ;
    rr:objectMap [ rr:parentTriplesMap <#NetworkConnectionMapping> ] ;
  ] ;
  # Link to Client
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasConnectedClient ;
    rr:objectMap [ rr:parentTriplesMap <#ClientMapping> ] ;
  ] ;
  # Link to ConnectPacket
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:receivesConnectPacket ;
    rr:objectMap [ rr:parentTriplesMap <#ConnectPacketMapping> ] ;
  ] .

############################
# MQTT Client
############################

<#ClientMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/Client_{network.client.clientID}" ;
    rr:class mqtt4ssn:Client
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasClientID ;
    rr:objectMap [ rml:reference "network.client.clientID" ; rr:datatype xsd:string ]
  ] ;

  # Link to Broker
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:isConnectedToBroker ;
    rr:objectMap [ rr:parentTriplesMap <#BrokerMapping> ] ;
  ] ;
  # Link to ConnectPacket
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:sendsConnectPacket ;
    rr:objectMap [ rr:parentTriplesMap <#ConnectPacketMapping> ] ;
  ] .