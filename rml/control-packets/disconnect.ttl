@base <http://example.com/mapping/> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rr:       <http://www.w3.org/ns/r2rml#> .
@prefix rml:      <http://semweb.mmlab.be/ns/rml#> .
@prefix ql:       <http://semweb.mmlab.be/ns/ql#> .
@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt:     <http://qudt.org/schema/qudt/> .
@prefix unit:     <http://qudt.org/vocab/unit/> .
@prefix mqtt4ssn: <https://doernern.github.io/MQTT4SSNOntology/MQTT4SSN.owl#> .

###################################
# Logical source: Node-RED JSON file
###################################
<#Base>
  rml:source "/work/data/in/disconnect.json" ;
  rml:referenceFormulation ql:JSONPath ;
  rml:iterator "$[*]" .

############################
# MQTT DisconnectPacket
############################

<#DisconnectPacketMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/DisconnectPacket_{timestamp}" ;
    rr:class mqtt4ssn:DisconnectPacket
  ] ;

  # Link to DisconnectFixedHeader
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasDisconnectFixedHeader ;
    rr:objectMap [ rr:parentTriplesMap <#DisconnectFixedHeaderMapping> ] ;
  ] ;
  # Link to DisconnectVariableHeader
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasDisconnectVariableHeader ;
    rr:objectMap [ rr:parentTriplesMap <#DisconnectVariableHeaderMapping> ] ;
  ] .

############################
# MQTT DisconnectFixedHeader
############################

<#DisconnectFixedHeaderMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/DisconnectFixedHeader_{timestamp}" ;
    rr:class mqtt4ssn:DisconnectFixedHeader
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasControlPacketType ;
    rr:objectMap [ rml:reference "disconnectPacket.fixedHeader.controlPacketType" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasRemainingLength ;
    rr:objectMap [ rml:reference "disconnectPacket.fixedHeader.remainingLength" ; rr:datatype xsd:byte ]
  ] .

############################
# MQTT DisconnectVariableHeader
############################

<#DisconnectVariableHeaderMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/DisconnectVariableHeader_{timestamp}" ;
    rr:class mqtt4ssn:DisconnectVariableHeader
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasDisconnectReasonCode ;
    rr:objectMap [ rml:reference "disconnectPacket.variableHeader.disconnectReasonCode" ; rr:datatype xsd:string ]
  ] ;

  # Link to DisconnectProperties
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasDisconnectProperties ;
    rr:objectMap [ rr:parentTriplesMap <#DisconnectPropertiesMapping> ] ;
  ] .

<#DisconnectPropertiesMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/DisconnectProperties_{timestamp}" ;
    rr:class mqtt4ssn:DisconnectProperties
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPropertyLength ;
    rr:objectMap [ rml:reference "disconnectPacket.variableHeader.disconnectProperties.propertyLength" ; rr:datatype xsd:nonNegativeInteger ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasSessionExpiryInterval ;
    rr:objectMap [ rml:reference "disconnectPacket.variableHeader.disconnectProperties.sessionExpiryInterval" ; rr:datatype xsd:unsignedInt ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasReasonString ;
    rr:objectMap [ rml:reference "disconnectPacket.variableHeader.disconnectProperties.reasonString" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasUserProperty ;
    rr:objectMap [ rml:reference "disconnectPacket.variableHeader.disconnectProperties.userProperty" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasServerReference ;
    rr:objectMap [ rml:reference "disconnectPacket.variableHeader.disconnectProperties.serverReference" ; rr:datatype xsd:string ]
  ] .

############################
# MQTT NetworkConnection
############################

<#NetworkConnectionMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/NetworkConnection_{network.connection}" ;
    rr:class mqtt4ssn:NetworkConnection
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:usesTLS ;
    rr:objectMap [ rml:reference "network.tls" ; rr:datatype xsd:boolean ]
  ] ;

  # Link to Client
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:isInitiatedBy ;
    rr:objectMap [ rr:parentTriplesMap <#ClientMapping> ] ;
  ] ;
  # Link to NetworkParticipants
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasParticipant ;
    rr:objectMap [ rr:parentTriplesMap <#BrokerMapping> ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasParticipant ;
    rr:objectMap [ rr:parentTriplesMap <#ClientMapping> ] ;
  ] .

############################
# MQTT Broker
############################

<#BrokerMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/Broker_{network.broker.brokerID}" ;
    rr:class mqtt4ssn:Broker
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasHostAddress ;
    rr:objectMap [ rml:reference "network.broker.hostAddress" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPortNumber ;
    rr:objectMap [ rml:reference "network.broker.portNumber" ; rr:datatype xsd:unsignedShort ]
  ] ;

  # Link to NetworkConnectionMapping
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:isAcceptedBy ;
    rr:objectMap [ rr:parentTriplesMap <#NetworkConnectionMapping> ] ;
  ] ;
  # Link to Client
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasConnectedClient ;
    rr:objectMap [ rr:parentTriplesMap <#ClientMapping> ] ;
  ] ;
  # Link to DisconnectPacket
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:receivesDisconnectPacket ;
    rr:objectMap [ rr:parentTriplesMap <#DisconnectPacketMapping> ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:sendsDisconnectPacket ;
    rr:objectMap [ rr:parentTriplesMap <#DisconnectPacketMapping> ] ;
  ] .

############################
# MQTT Client
############################

<#ClientMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/Client_{network.client.clientID}" ;
    rr:class mqtt4ssn:Client
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasClientID ;
    rr:objectMap [ rml:reference "network.client.clientID" ; rr:datatype xsd:string ]
  ] ;

  # Link to Broker
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:isConnectedToBroker ;
    rr:objectMap [ rr:parentTriplesMap <#BrokerMapping> ] ;
  ] ;
  # Link to DisconnectPacket
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:receivesDisconnectPacket ;
    rr:objectMap [ rr:parentTriplesMap <#DisconnectPacketMapping> ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:sendsDisconnectPacket ;
    rr:objectMap [ rr:parentTriplesMap <#DisconnectPacketMapping> ] ;
  ] .