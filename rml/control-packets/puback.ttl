@base <http://example.com/mapping/> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rr:       <http://www.w3.org/ns/r2rml#> .
@prefix rml:      <http://semweb.mmlab.be/ns/rml#> .
@prefix ql:       <http://semweb.mmlab.be/ns/ql#> .
@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt:     <http://qudt.org/schema/qudt/> .
@prefix unit:     <http://qudt.org/vocab/unit/> .
@prefix mqtt4ssn: <https://doernern.github.io/MQTT4SSNOntology/MQTT4SSN.owl#> .

###################################
# Logical source: Node-RED JSON file
###################################
<#Base>
  rml:source "/work/data/in/puback.json" ;
  rml:referenceFormulation ql:JSONPath ;
  rml:iterator "$" .

############################
# MQTT PubackPacket
############################

<#PubackPacketMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/PubackPacket_{timestamp}" ;
    rr:class mqtt4ssn:PubackPacket
  ] ;

  # Link to PubackFixedHeader
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPubackFixedHeader ;
    rr:objectMap [ rr:parentTriplesMap <#PubackFixedHeaderMapping> ] ;
  ] ;
  # Link to PubackVariableHeader
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPubackVariableHeader ;
    rr:objectMap [ rr:parentTriplesMap <#PubackVariableHeaderMapping> ] ;
  ] .

############################
# MQTT PubackFixedHeader
############################

<#PubackFixedHeaderMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/PubackFixedHeader_{timestamp}" ;
    rr:class mqtt4ssn:PubackFixedHeader
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasControlPacketType ;
    rr:objectMap [ rml:reference "pubackPacket.fixedHeader.controlPacketType" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasRemainingLength ;
    rr:objectMap [ rml:reference "pubackPacket.fixedHeader.remainingLength" ; rr:datatype xsd:byte ]
  ] .

############################
# MQTT PubackVariableHeader
############################

<#PubackVariableHeaderMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/PubackVariableHeader_{timestamp}" ;
    rr:class mqtt4ssn:PubackVariableHeader
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPacketIdentifier ;
    rr:objectMap [ rml:reference "pubackPacket.variableHeader.packetIdentifier" ; rr:datatype xsd:unsignedShort ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPubackReasonCode ;
    rr:objectMap [ rml:reference "pubackPacket.variableHeader.pubackReasonCode" ; rr:datatype xsd:string ]
  ] ;

  # Link to PubackProperties
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPubackProperties ;
    rr:objectMap [ rr:parentTriplesMap <#PubackPropertiesMapping> ] ;
  ] .

<#PubackPropertiesMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/PubackProperties_{timestamp}" ;
    rr:class mqtt4ssn:PubackProperties
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPropertyLength ;
    rr:objectMap [ rml:reference "pubackPacket.variableHeader.pubackProperties.propertyLength" ; rr:datatype xsd:nonNegativeInteger ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasReasonString ;
    rr:objectMap [ rml:reference "pubackPacket.variableHeader.pubackProperties.reasonString" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasUserProperty ;
    rr:objectMap [ rml:reference "pubackPacket.variableHeader.pubackProperties.userProperty" ; rr:datatype xsd:string ]
  ] .

############################
# MQTT NetworkConnection
############################

<#NetworkConnectionMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/NetworkConnection_{network.connection}" ;
    rr:class mqtt4ssn:NetworkConnection
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:usesTLS ;
    rr:objectMap [ rml:reference "network.tls" ; rr:datatype xsd:boolean ]
  ] ;

  # Link to Client
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:isInitiatedBy ;
    rr:objectMap [ rr:parentTriplesMap <#ClientMapping> ] ;
  ] ;
  # Link to NetworkParticipants
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasParticipant ;
    rr:objectMap [ rr:parentTriplesMap <#BrokerMapping> ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasParticipant ;
    rr:objectMap [ rr:parentTriplesMap <#ClientMapping> ] ;
  ] .

############################
# MQTT Broker
############################

<#BrokerMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/Broker_{network.broker.brokerID}" ;
    rr:class mqtt4ssn:Broker
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasHostAddress ;
    rr:objectMap [ rml:reference "network.broker.hostAddress" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPortNumber ;
    rr:objectMap [ rml:reference "network.broker.portNumber" ; rr:datatype xsd:unsignedShort ]
  ] ;

  # Link to NetworkConnectionMapping
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:isAcceptedBy ;
    rr:objectMap [ rr:parentTriplesMap <#NetworkConnectionMapping> ] ;
  ] ;
  # Link to Client
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasConnectedClient ;
    rr:objectMap [ rr:parentTriplesMap <#ClientMapping> ] ;
  ] ;
  # Link to PubackPacket
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:receivesPubackPacket ;
    rr:objectMap [ rr:parentTriplesMap <#PubackPacketMapping> ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:sendsPubackPacket ;
    rr:objectMap [ rr:parentTriplesMap <#PubackPacketMapping> ] ;
  ] .

############################
# MQTT Client
############################

<#ClientMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/Client_{network.client.clientID}" ;
    rr:class mqtt4ssn:Client
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasClientID ;
    rr:objectMap [ rml:reference "network.client.clientID" ; rr:datatype xsd:string ]
  ] ;

  # Link to Broker
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:isConnectedToBroker ;
    rr:objectMap [ rr:parentTriplesMap <#BrokerMapping> ] ;
  ] ;
  # Link to PubackPacket
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:receivesPubackPacket ;
    rr:objectMap [ rr:parentTriplesMap <#PubackPacketMapping> ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:sendsPubackPacket ;
    rr:objectMap [ rr:parentTriplesMap <#PubackPacketMapping> ] ;
  ] .