@base <http://example.com/mapping/> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rr:       <http://www.w3.org/ns/r2rml#> .
@prefix rml:      <http://semweb.mmlab.be/ns/rml#> .
@prefix ql:       <http://semweb.mmlab.be/ns/ql#> .
@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt:     <http://qudt.org/schema/qudt/> .
@prefix unit:     <http://qudt.org/vocab/unit/> .
@prefix mqtt4ssn: <https://doernern.github.io/MQTT4SSNOntology/MQTT4SSN.owl#> .

###################################
# Logical source: Node-RED JSON file
###################################
<#Base>
  rml:source "/work/data/in/unsubscribe.json" ;
  rml:referenceFormulation ql:JSONPath ;
  rml:iterator "$" .

############################
# MQTT UnsubscribePacket
############################

<#UnsubscribePacketMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/UnsubscribePacket_{timestamp}" ;
    rr:class mqtt4ssn:UnsubscribePacket
  ] ;

  # Link to UnsubscribeFixedHeader
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasUnsubscribeFixedHeader ;
    rr:objectMap [ rr:parentTriplesMap <#UnsubscribeFixedHeaderMapping> ] ;
  ] ;
  # Link to UnsubscribeVariableHeader
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasUnsubscribeVariableHeader ;
    rr:objectMap [ rr:parentTriplesMap <#UnsubscribeVariableHeaderMapping> ] ;
  ] ;
  # Link to UnsubscribePayload
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasUnsubscribePayload ;
    rr:objectMap [ rr:parentTriplesMap <#UnsubscribePayloadMapping> ] ;
  ] .

############################
# MQTT UnsubscribeFixedHeader
############################

<#UnsubscribeFixedHeaderMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/UnsubscribeFixedHeader_{timestamp}" ;
    rr:class mqtt4ssn:UnsubscribeFixedHeader
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasControlPacketType ;
    rr:objectMap [ rml:reference "unsubscribePacket.fixedHeader.controlPacketType" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasRemainingLength ;
    rr:objectMap [ rml:reference "unsubscribePacket.fixedHeader.remainingLength" ; rr:datatype xsd:byte ]
  ] .

############################
# MQTT UnsubscribeVariableHeader
############################

<#UnsubscribeVariableHeaderMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/UnsubscribeVariableHeader_{timestamp}" ;
    rr:class mqtt4ssn:UnsubscribeVariableHeader
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPacketIdentifier ;
    rr:objectMap [ rml:reference "unsubscribePacket.variableHeader.packetIdentifier" ; rr:datatype xsd:integer ]
  ] ;

  # Link to UnsubscribeProperties
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasUnsubscribeProperties ;
    rr:objectMap [ rr:parentTriplesMap <#UnsubscribePropertiesMapping> ] ;
  ] .

<#UnsubscribePropertiesMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/UnsubscribeProperties_{timestamp}" ;
    rr:class mqtt4ssn:UnsubscribeProperties
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPropertyLength ;
    rr:objectMap [ rml:reference "unsubscribePacket.variableHeader.unsubscribeProperties.propertyLength" ; rr:datatype xsd:integer ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasUserProperty ;
    rr:objectMap [ rml:reference "unsubscribePacket.variableHeader.unsubscribeProperties.userProperty" ; rr:datatype xsd:string ]
  ] .

############################
# MQTT UnsubscribePayload
############################

<#UnsubscribePayloadMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/UnsubscribePayload_{timestamp}" ;
    rr:class mqtt4ssn:UnsubscribePayload
  ] ;

  #Link to TopicFilter
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasTopicFilter ;
    rr:objectMap [ rr:parentTriplesMap <#TopicFilterMapping> ] ;
  ] .

############################
# TopicFilter
############################

<#TopicFilterMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/Topic_{unsubscribePacket.payload.topicFilter}" ;
    rr:class mqtt4ssn:TopicFilter ;
  ] ;

  rr:predicateObjectMap [
    rr:predicate rdfs:label;
    rr:objectMap [ rml:reference "unsubscribePacket.payload.topicFilter" ; rr:datatype xsd:string ] ;
  ] .

############################
# MQTT NetworkConnection
############################

<#NetworkConnectionMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/NetworkConnection_{network.sonnection}" ;
    rr:class mqtt4ssn:NetworkConnection
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:usesTLS ;
    rr:objectMap [ rml:reference "network.tls" ; rr:datatype xsd:boolean ]
  ] ;

  # Link to Client
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:isInitiatedBy ;
    rr:objectMap [ rr:parentTriplesMap <#ClientMapping> ] ;
  ] ;
  # Link to NetworkParticipants
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasParticipant ;
    rr:objectMap [ rr:parentTriplesMap <#BrokerMapping> ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasParticipant ;
    rr:objectMap [ rr:parentTriplesMap <#ClientMapping> ] ;
  ] .

############################
# MQTT Broker
############################

<#BrokerMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/Broker_{network.broker.brokerID}" ;
    rr:class mqtt4ssn:Broker
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasHostAddress ;
    rr:objectMap [ rml:reference "network.broker.hostAddress" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasPortNumber ;
    rr:objectMap [ rml:reference "network.broker.portNumber" ; rr:datatype xsd:integer ]
  ] ;

  # Link to NeworkConnection
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:isAcceptedBy ;
    rr:objectMap [ rr:parentTriplesMap <#NetworkConnectionMapping> ] ;
  ] ;
  # Link to Client
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasConnectedClient ;
    rr:objectMap [ rr:parentTriplesMap <#ClientMapping> ] ;
  ] ;
  # Link to UnsubscribePacket
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:receivesUbsubscribePacket ;
    rr:objectMap [ rr:parentTriplesMap <#UnsubscribePacketMapping> ] ;
  ] .

############################
# MQTT Client
############################

<#ClientMapping>
  a rr:TriplesMap ;
  rml:logicalSource <#Base> ;

  rr:subjectMap [
    rr:template "http://example.org/Client_{network.client.clientID}" ;
    rr:class mqtt4ssn:Client
  ] ;

  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:hasClientID ;
    rr:objectMap [ rml:reference "network.client.clientID" ; rr:datatype xsd:integer ]
  ] ;

  # Link to Broker
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:isConnectedToBroker ;
    rr:objectMap [ rr:parentTriplesMap <#BrokerMapping> ] ;
  ] ;
  # Link to UnsubscribePacket
  rr:predicateObjectMap [
    rr:predicate mqtt4ssn:sendsUnsubscribePacket ;
    rr:objectMap [ rr:parentTriplesMap <#UnsubscribePacketMapping> ] ;
  ] .